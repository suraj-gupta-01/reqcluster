# ReqCluster configuration template
# Copy to .env and adjust. The backend auto-loads .env at startup (no extra deps).
# Anything left unset uses a safe local-dev default, so an empty .env still runs.

# ==========================================================================
# Database
# ==========================================================================
# Unset  -> SQLite at backend/data/reqcluster.db (local dev; a startup warning
#           is logged). Set REQCLUSTER_SQLITE_OK=1 to silence that warning.
# Set    -> PostgreSQL (recommended for >20k requirements / multi-user).
#
# DATABASE_URL=postgresql://reqcluster:reqcluster_dev_password@localhost:5432/reqcluster
# REQCLUSTER_SQLITE_OK=1

# ==========================================================================
# Redis - per-text embedding cache (optional)
# ==========================================================================
# When set, individual text embeddings are cached (so re-runs / incremental
# additions skip re-encoding). Falls back to an on-disk .npy cache when unset.
# REDIS_URL=redis://localhost:6379

# ==========================================================================
# CORS - allowed frontend origins (comma-separated)
# ==========================================================================
# Defaults to the Vite dev server and the Docker frontend.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================================================
# Compute / acceleration  (informational - auto-detected, no env needed)
# ==========================================================================
# Embeddings run on the GPU automatically when a CUDA build of torch is present
# (check with: python backend/core/device.py). UMAP/HDBSCAN use a GPU (cuML)
# path on Linux/WSL when available, else an adaptive parallel-CPU path.
# Optional override of the small-vs-large adaptive threshold:
# REQCLUSTER_SMALL_N=4000

# ==========================================================================
# LLM provider (enrichment, refinement rationales, summaries)
# ==========================================================================
# "mock"  -> deterministic, fully offline (default; no model needed)
# "local" -> on-prem model via Ollama / vLLM (this machine)
# "openai"-> any OpenAI-compatible cloud gateway
REQCLUSTER_LLM_PROVIDER=mock

# --- Local model (Ollama native /api/generate, or vLLM) -------------------
# Start Ollama, then `ollama pull <model>`. Pick a model that fits free RAM:
#   ~1 GB free  -> qwen2.5:1.5b      ~3 GB free -> qwen2.5:3b
#   ~6 GB free  -> qwen2.5-coder:7b
REQCLUSTER_LOCAL_LLM_URL=http://localhost:11434/api/generate
REQCLUSTER_LOCAL_LLM_MODEL=qwen2.5-coder:7b
REQCLUSTER_LOCAL_LLM_TIMEOUT_SECONDS=120

# --- OpenAI-compatible cloud (Groq, OpenRouter, OpenAI, ...) --------------
# REQCLUSTER_LLM_BASE_URL=https://api.groq.com/openai/v1
# REQCLUSTER_LLM_API_KEY=your_api_key_here
# REQCLUSTER_LLM_MODEL=llama-3.3-70b-versatile
# REQCLUSTER_LLM_TIMEOUT_SECONDS=30.0
# REQCLUSTER_LLM_MAX_RETRIES=2
