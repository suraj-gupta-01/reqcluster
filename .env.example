# ReqCluster Configuration Template
# Copy this file to .env and fill in your details.

# Provider selection: "mock" (offline/deterministic), "openai" (OpenAI-compatible cloud), or "local" (on-premise model)
REQCLUSTER_LLM_PROVIDER=mock

# ==========================================
# OpenAI / OpenAI-Compatible Configuration
# ==========================================
# Base URL for the OpenAI-compatible API (e.g., Groq, OpenRouter, OpenAI, etc.)
# For Groq, use: https://api.groq.com/openai/v1
# For OpenAI, use: https://api.openai.com/v1
REQCLUSTER_LLM_BASE_URL=https://api.groq.com/openai/v1

# API Key for the selected provider
REQCLUSTER_LLM_API_KEY=your_api_key_here

# Model name to use
# For Groq, e.g.: llama-3.3-70b-versatile, mixtral-8x7b-32768
# For OpenAI, e.g.: gpt-4o-mini
REQCLUSTER_LLM_MODEL=llama-3.3-70b-versatile

# Optional settings
REQCLUSTER_LLM_TIMEOUT_SECONDS=30.0
REQCLUSTER_LLM_MAX_RETRIES=2

# ==========================================
# Local LLM Configuration (e.g., Ollama, vLLM)
# ==========================================
# Endpoint for your locally hosted LLM (use /api/generate for Ollama native)
REQCLUSTER_LOCAL_LLM_URL=http://localhost:11434/api/generate
REQCLUSTER_LOCAL_LLM_MODEL=qwen2.5-coder:7b
REQCLUSTER_LOCAL_LLM_TIMEOUT_SECONDS=30.0
